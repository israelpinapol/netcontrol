# ── Selección de backend ─────────────────────────────────────────────
# demo    -> datos simulados (por defecto, no requiere nada)
# adguard -> AdGuard Home real (DNS: filtrado de webs/apps, gratis)
# openwrt -> OpenWRT real (gateway: admitir/echar dispositivos + portal cautivo, gratis)
NETCONTROL_BACKEND=demo

# ── AdGuard Home (sólo si NETCONTROL_BACKEND=adguard) ─────────────────
# URL de tu AdGuard Home: su IP en la LAN, o la URL del túnel (Cloudflare/Tailscale)
ADGUARD_URL=http://192.168.1.10:3000
ADGUARD_USER=admin
ADGUARD_PASS=cambia_esto
# Nombre estético que se muestra en el panel (opcional)
ADGUARD_ROUTER_NAME=Casa - AdGuard Home

# ── OpenWRT (sólo si NETCONTROL_BACKEND=openwrt) ─────────────────────
# Control REAL del gateway: admitir/echar dispositivos, portal cautivo, ancho de banda.
# Requiere en el router: luci-mod-rpc, rpcd-mod-file, opennds (portal), nlbwmon (opcional).
OPENWRT_URL=http://192.168.1.1
OPENWRT_USER=root
OPENWRT_PASS=cambia_esto
OPENWRT_ROUTER_NAME=Casa - OpenWRT
